# Test environment — used by `bun test` and `bun run test:run`
# Points at the isolated test DB (port 5433) so tests never touch dev data

NODE_ENV=test
PORT=3002

DATABASE_URL=postgresql://supplymind:supplymind@localhost:5433/supplymind_test
REDIS_URL=redis://localhost:6379

# No Clerk in tests — dev-mode decode is fine
CLERK_SECRET_KEY=

# Stub AI keys so imports don't fail
ANTHROPIC_API_KEY=test-key
OPENAI_API_KEY=test-key
GOOGLE_API_KEY=test-key

A2A_API_KEY=test-a2a-key
LOG_LEVEL=warn
