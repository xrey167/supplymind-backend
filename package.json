{
  "name": "supplymind-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --env-file .env.development --watch src/index.ts",
    "build": "bun build src/index.ts --outdir dist --target bun --external playwright --external playwright-core",
    "start": "bun run dist/index.js",
    "db:generate": "bun run --env-file .env.development --bun node_modules/.bin/drizzle-kit generate",
    "db:migrate": "bun run --env-file .env.development --bun node_modules/.bin/drizzle-kit migrate",
    "db:migrate:test": "bun run --env-file .env.test --bun node_modules/.bin/drizzle-kit migrate",
    "db:push": "bun run --env-file .env.development --bun node_modules/.bin/drizzle-kit push",
    "db:studio": "bun run --env-file .env.development --bun node_modules/.bin/drizzle-kit studio",
    "db:setup": "bun run db:migrate && bun run db:migrate:test && bun run seed",
    "test": "bun test",
    "test:run": "bun test",
    "test:integration": "bun run --env-file .env.test scripts/test-runner.ts tests/integration/",
    "test:e2e": "bun run --env-file .env.test scripts/test-runner.ts tests/e2e/",
    "seed": "bun run --env-file .env.development scripts/seed.ts",
    "create-admin": "bun run --env-file .env.development scripts/create-admin.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@clerk/backend": "^3.2.4",
    "@google/genai": "^1.48.0",
    "@hono/zod-openapi": "^1.2.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@novu/api": "^3.14.3",
    "@openfeature/core": "^1.9.2",
    "@openfeature/server-sdk": "^1.20.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@react-email/components": "^1.0.11",
    "@react-email/render": "^2.0.5",
    "@sentry/node": "^10.47.0",
    "bullmq": "^5.73.0",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.10",
    "ioredis": "^5.10.1",
    "jose": "^6.2.2",
    "nanoid": "^5.1.7",
    "nodemailer": "^8.0.4",
    "openai": "^6.33.0",
    "pino": "^10.3.1",
    "playwright": "^1.59.1",
    "postgres": "^3.4.8",
    "react-email": "^5.2.10",
    "resend": "^6.10.0",
    "stripe": "^17.7.0",
    "superjson": "^2.2.6",
    "ts-pattern": "^5.9.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/nodemailer": "^7.0.11",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
