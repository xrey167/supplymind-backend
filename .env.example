# Copy this file to .env and fill in real values
# See .env.development for local dev defaults (works with docker-compose up)

NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://user:password@localhost:5432/supplymind_dev
REDIS_URL=redis://localhost:6379

# Clerk auth — leave blank for insecure dev-mode JWT decode
CLERK_SECRET_KEY=

# AI providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# A2A endpoint secret
A2A_API_KEY=

# Observability
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=supplymind-backend

# Email / Notifications
RESEND_API_KEY=
NOVU_API_KEY=

LOG_LEVEL=info

# ERP BC integration tests (optional -- skip if not set)
BC_TENANT_ID=
BC_CLIENT_ID=
BC_CLIENT_SECRET=
BC_BASE_URL=https://api.businesscentral.dynamics.com/v2.0/{tenantId}/Production/ODataV4
BC_COMPANY_ID=
