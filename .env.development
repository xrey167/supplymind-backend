# Development environment — used by `bun run dev` and `bun run seed`
# Copy to .env and fill in real values, or use as-is with docker-compose up

NODE_ENV=development
PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://supplymind:supplymind@localhost:5432/supplymind_dev

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth (Clerk) ──────────────────────────────────────────────────────────────
# Leave blank to use insecure dev-mode JWT decode (no Clerk account needed)
CLERK_SECRET_KEY=

# ── AI Providers (all optional) ───────────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── A2A public endpoint ───────────────────────────────────────────────────────
# Secret key protecting the /a2a JSON-RPC endpoint
A2A_API_KEY=dev-a2a-key

# ── Observability (all optional) ──────────────────────────────────────────────
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=supplymind-backend

# ── Email / Notifications (optional) ─────────────────────────────────────────
RESEND_API_KEY=
NOVU_API_KEY=

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug
